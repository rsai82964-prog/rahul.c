#include<stdio.h>
int main()
{
    int arr[]={0,1,9,8,0,2};
    int n=6,i,j=0,temp;

    for(i=0;i<n;i++)
    {
        if(arr[i]!=0)
        {
            temp=arr[i];
            arr[i]=arr[j];
            arr[j]=temp;
            j++; 
        }
    }

    for(i=0;i<n;i++)
        printf("%d ",arr[i]);
}
