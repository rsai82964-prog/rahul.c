#include<stdio.h>

int reverse(int n)
{
    int r,rev=0;
    while(n!=0)
    {
        r=n%10; 
        rev=rev*10+r;
        n=n/10;
    }
    return rev;
}

int main()
{
    int n;
    scanf("%d",&n);

    if(n==reverse(n))
        printf("Palindrome");
    else
        printf("Not Palindrome");
}
