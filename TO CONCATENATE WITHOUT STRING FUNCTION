#include <stdio.h>

int main()
{
    char str1[100]="RAHUL"; 
    char str2[100]="SAI";
    int i = 0, j = 0;
    scanf("%s", str1);
    scanf("%s", str2);

    while(str1[i] != '\0')
    {
        i++;
    }

    while(str2[j] != '\0')
    {
        str1[i] = str2[j];
        i++;
        j++;
    }

    str1[i] = '\0';

    printf("Concatenated string: %s", str1);

    return 0;
}
