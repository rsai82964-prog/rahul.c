#include<stdio.h>
int main()
{
    int arr[]={1,2,2,4,5};
    int n=5,i,j;

    for(i=0;i<n;i++) 
    {
        for(j=i+1;j<n;j++) 
        {
            if(arr[i]==arr[j])
                printf("Repeating = %d\n",arr[i]);
        }
    }

    for(i=1;i<=n;i++)
    {
        int found=0;
        for(j=0;j<n;j++)
        {
            if(arr[j]==i)
                found=1;
        }
        if(!found)
            printf("Missing = %d",i);
    }
}
