#include<stdio.h>
int main()
{
    int arr[]={2,2,1,2,3,2,2};
    int n=7,i,j,count;

    for(i=0;i<n;i++)
    {
        count=0;
        for(j=0;j<n;j++)
        {
            if(arr[i]==arr[j])
                count++;
        } 

        if(count>n/2)
        {
            printf("Majority element = %d",arr[i]);
            break;
        }
    }
}
