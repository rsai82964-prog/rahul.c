#include<stdio.h>
int main()
{ 
    int arr[]={1,2,3,4,5};
    int n=5,i,flag=1;

    for(i=0;i<n-1;i++)
    {
        if(arr[i]>arr[i+1])
        {
            flag=0;
            break;
        }
    }

    if(flag)
        printf("Array is sorted");
    else
        printf("Array is not sorted");
}
